{
  "name": "skygems-monorepo",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @skygems/web",
    "dev:api": "npm run dev --workspace @skygems/api",
    "db:migrate:local": "npm run db:migrate:local --workspace @skygems/api",
    "db:migrate:remote": "npm run db:migrate:remote --workspace @skygems/api",
    "build:web": "npm run build --workspace @skygems/web",
    "cf:typegen": "npm run cf:typegen --workspace @skygems/api",
    "typecheck": "npm run cf:typegen && npm run typecheck --workspace @skygems/shared && npm run typecheck --workspace @skygems/api && npm run typecheck --workspace @skygems/web",
    "test": "node --experimental-strip-types --test packages/shared/src/**/*.test.ts apps/api/test/**/*.test.ts",
    "validate": "npm run typecheck && npm run test && npm run build:web"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "typescript": "5.9.2",
    "wrangler": "4.44.0"
  }
}
